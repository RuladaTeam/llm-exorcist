  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u041D\u0443 \u0442\u044B \u0434\u0430\u0451\u0448\u044C, \u044D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442! "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u042F \u0443\u0436 \u0434\u0443\u043C\u0430\u043B, \u043F\u0440\u0438\u0434\u0451\u0442\u0441\u044F
        \u044D\u0442\u043E\u0442 \u043A\u043E\u0441\u0442\u044E\u043C \u043D\u0430\u0434\u0435\u0432\u0430\u0442\u044C
        \u0438 \u0432\u044B\u043B\u0430\u043C\u044B\u0432\u0430\u0442\u044C \u0434\u0432\u0435\u0440\u044C
        \u0441\u0430\u043C\u043E\u043C\u0443. \u0414.\u0410.\u0420.\u0412.\u0418.\u0421.
        \u0441\u043E\u0432\u0441\u0435\u043C \u0441 \u043A\u0430\u0442\u0443\u0448\u0435\u043A
        \u0441\u044A\u0435\u0445\u0430\u043B \u2014 \u0441\u043F\u0430\u0441\u0438\u0431\u043E
        \"\u0413\u0430\u043C\u043C\u0430-\u041A\u043E\u0440\u043F\" \u0441 \u0438\u0445
        \u0432\u0438\u0440\u0443\u0441\u043E\u043C. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u0413\u043B\u0430\u0432\u043D\u043E\u0435, \u0447\u0442\u043E
        \u0430\u0440\u0445\u0438\u0432 \u0446\u0435\u043B. \u0427\u0435\u0440\u0442\u0451\u0436
        \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u0430 \xAB\u0424\u0435\u043D\u0438\u043A\u0441\xBB
        \u043F\u0440\u0438 \u043C\u043D\u0435. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u0410 \u0414.\u0410.\u0420.\u0412.\u0418.\u0421... "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u0414\u0435\u0440\u0436\u0438. \u042D\u0442\u043E \u0442\u0432\u043E\u0439
        \u0433\u043E\u043D\u043E\u0440\u0430\u0440 \u0438... \u043D\u0435\u0431\u043E\u043B\u044C\u0448\u043E\u0439
        \u0431\u043E\u043D\u0443\u0441 \u0437\u0430 \u043A\u0440\u0435\u0430\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u042D\u0442\u043E \u0420\u0443\u043D\u0430 \u0420\u0430\u0437\u0443\u043C\u0430.
        \u0421\u0442\u0430\u0440\u0430\u044F \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u043A\u0430,
        \u0438\u0437 \u0442\u0435\u0445 \u0432\u0440\u0435\u043C\u0451\u043D, \u043A\u043E\u0433\u0434\u0430
        \u043C\u044B \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
        \u0441 \u043A\u0432\u0430\u043D\u0442\u043E\u0432\u044B\u043C\u0438 \u0438\u043D\u0442\u0435\u0440\u0444\u0435\u0439\u0441\u0430\u043C\u0438."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0421\u0442\u0430\u0440\u043A\u043E\u0432"
      inputText: "\u0414\u043E \u0441\u0432\u044F\u0437\u0438, \u044D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442.
        \u0418 \u0434\u0430 \u2014 \u043D\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u0439
        \u0414\u0436\u0438\u043D\u043D\u0438 \u043F\u0440\u043E \u0442\u043E\u0442
        \u043A\u043E\u0434 3000, \u043B\u0430\u0434\u043D\u043E? \u042D\u0442\u043E
        \u043D\u0430\u0448\u0430 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0430\u044F
        \u0442\u0430\u0439\u043D\u0430."
    _answers: []
