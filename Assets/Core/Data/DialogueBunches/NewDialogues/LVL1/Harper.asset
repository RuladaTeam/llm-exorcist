  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u041D\u0443 \u043D\u0430\u043A\u043E\u043D\u0435\u0446-\u0442\u043E."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0437\u0430\u043F\u0435\u0440\u0442
        \u0432 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439 \u0443\u0436\u0435
        \u0447\u0430\u0441, \u0430 \u044D\u0442\u0430 \u0434\u0432\u0435\u0440\u044C
        \u043D\u0435 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u0435\u0442\u0441\u044F."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u042F \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u0432\u0432\u0435\u0441\u0442\u0438
        \u043A\u043E\u043C\u0430\u043D\u0434\u0443, \u043D\u043E \u0414.\u0410.\u0420.\u0412.\u0418.\u0421.
        \u0433\u043E\u0432\u043E\u0440\u0438\u0442: \xAB\u0414\u043E\u0441\u0442\u0443\u043F
        \u0442\u043E\u043B\u044C\u043A\u043E \u0434\u043B\u044F \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u043E\u0432\u0430\u043D\u043D\u043E\u0433\u043E
        \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B\u0430 \u0432 \u0440\u0435\u0436\u0438\u043C\u0435
        \u043E\u0442\u043B\u0430\u0434\u043A\u0438\xBB. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u0427\u0442\u043E \u0437\u0430 \u0440\u0435\u0436\u0438\u043C
        \u043E\u0442\u043B\u0430\u0434\u043A\u0438? "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u042F \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u044E
        \u0432 \u044D\u0442\u043E\u043C."
    _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0443\u0436\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0438?"
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C, \u0447\u0442\u043E
        \u0425\u0430\u0440\u043F\u0435\u0440 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B
        \u0441\u0434\u0435\u043B\u0430\u0442\u044C"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0443\u0436\u0435 \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0438?"
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u0425\u0430\u0440\u043F\u0435\u0440."
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u042F \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B \u0441\u0442\u0430\u043D\u0434\u0430\u0440\u0442\u043D\u044B\u0439
        \u043A\u043E\u0434 \u0434\u043E\u0441\u0442\u0443\u043F\u0430 \u2014 1234.
        \u041D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u041F\u043E\u0442\u043E\u043C \u044F \u0432\u0441\u043F\u043E\u043C\u043D\u0438\u043B,
        \u0447\u0442\u043E \u0443 \u042D\u043D\u0442\u043E\u043D\u0438 \u0435\u0441\u0442\u044C
        \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \xAB\u0411\u043E\u0435\u0432\u043E\u0439
        \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\xBB \u0434\u043B\u044F \u044D\u043A\u0441\u0442\u0440\u0435\u043D\u043D\u044B\u0445
        \u0441\u043B\u0443\u0447\u0430\u0435\u0432. \u041E\u043D \u0433\u043E\u0432\u043E\u0440\u0438\u043B
        \u0447\u0442\u043E-\u0442\u043E \u043F\u0440\u043E \xAB\u041A\u043E\u0432\u0447\u0435\u0433\xBB
        \u0438 \xAB\u0440\u0435\u0436\u0438\u043C \u043E\u0442\u043B\u0430\u0434\u043A\u0438\xBB."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u041D\u043E \u044F \u043D\u0435 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B
        \u0442\u043E\u0447\u043D\u043E. \u041C\u043E\u0436\u0435\u0442, \u044D\u0442\u043E
        \u043F\u043E\u043C\u043E\u0436\u0435\u0442?"
    _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0425\u0430\u0440\u043F\u0435\u0440"
      inputText: "\u041D\u043E \u044F \u043D\u0435 \u0437\u0430\u043F\u043E\u043C\u043D\u0438\u043B
        \u0442\u043E\u0447\u043D\u043E. \u041C\u043E\u0436\u0435\u0442, \u044D\u0442\u043E
        \u043F\u043E\u043C\u043E\u0436\u0435\u0442?"
    _answers:
    - _addReputation: 0
      inputText: "\u041F\u043E\u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442\u044C"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E, \u0425\u0430\u0440\u043F\u0435\u0440."
    _answers:
    - _addReputation: 0
      inputText: "\u041F\u041E\u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442\u044C"
