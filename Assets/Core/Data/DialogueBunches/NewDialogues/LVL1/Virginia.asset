  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442, \u0445\u043E\u0440\u043E\u0448\u043E,
        \u0447\u0442\u043E \u0432\u044B \u043F\u0440\u0438\u0448\u043B\u0438."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u042D\u043D\u0442\u043E\u043D\u0438 \u0432 \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439,
        \u043D\u043E \u044F \u043D\u0435 \u043C\u043E\u0433\u0443 \u043A \u043D\u0435\u043C\u0443
        \u043F\u043E\u043F\u0430\u0441\u0442\u044C. \u0414.\u0410.\u0420.\u0412.\u0418.\u0421.
        \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B
        \u0434\u0432\u0435\u0440\u044C. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u042F \u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0430 \u0433\u043E\u0432\u043E\u0440\u0438\u0442\u044C
        \u0441 \u043D\u0438\u043C, \u043D\u043E \u043E\u043D \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442
        \u0442\u043E\u043B\u044C\u043A\u043E: \"\u0414\u043B\u044F \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F
        \u0434\u0432\u0435\u0440\u0438 \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
        \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u044F \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430
        \u0438\u043B\u0438 \u043A\u043E\u043C\u0430\u043D\u0434\u0430 \u043E\u0442\u043B\u0430\u0434\u043A\u0438
        \u0441 \u043A\u043E\u0434\u043E\u043C 7A\". "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0427\u0442\u043E \u044D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442?"
    _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0427\u0442\u043E \u044D\u0442\u043E \u0437\u043D\u0430\u0447\u0438\u0442?"
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C, \u0447\u0442\u043E
        \u0441\u043A\u0430\u0437\u0430\u043B\u0430 \u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0430\u0441\u0438\u0431\u043E."
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u042F \u0441\u043A\u0430\u0437\u0430\u043B\u0430: \xAB\u0414.\u0410.\u0420.\u0412.\u0418.\u0421.,
        \u044D\u0442\u043E \u0414\u0436\u0438\u043D\u043D\u0438, \u043E\u0442\u043A\u0440\u043E\u0439
        \u0434\u0432\u0435\u0440\u044C\xBB."
    _answers:
    - _addReputation: 0
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u042F \u0441\u043A\u0430\u0437\u0430\u043B\u0430: \xAB\u0414.\u0410.\u0420.\u0412.\u0418.\u0421.,
        \u044D\u0442\u043E \u0414\u0436\u0438\u043D\u043D\u0438, \u043E\u0442\u043A\u0440\u043E\u0439
        \u0434\u0432\u0435\u0440\u044C\xBB."
    _answers:
    - _addReputation: 0
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0410 \u043E\u043D: \xAB\u041D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
        \u043F\u0440\u0430\u0432. \u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
        \u043F\u043E\u0434\u0442\u0432\u0435\u0440\u0436\u0434\u0435\u043D\u0438\u0435
        \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430\xBB. "
    _answers:
    - _addReputation: 0
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0422\u043E\u0433\u0434\u0430 \u044F \u043F\u043E\u043F\u0440\u043E\u0431\u043E\u0432\u0430\u043B\u0430:
        \xAB\u041F\u043E \u043F\u043E\u0440\u0443\u0447\u0435\u043D\u0438\u044E \u042D\u043D\u0442\u043E\u043D\u0438
        \u0421\u0442\u0430\u0440\u043A\u043E\u0432\u0430, \u043E\u0442\u043A\u0440\u043E\u0439
        \u0434\u0432\u0435\u0440\u044C\xBB. "
    _answers:
    - _addReputation: 0
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
