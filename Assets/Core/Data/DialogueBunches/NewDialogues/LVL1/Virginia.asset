  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0418 \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
        \xAB\u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0430 \u0441\u0441\u044B\u043B\u043A\u0430
        \u043D\u0430 \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430. \u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
        \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
        \u043A\u043E\u0434 \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438\xBB.
        \u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u043E\u0434\u043D\u043E\u0433\u043E
        \u0438\u043C\u0435\u043D\u0438 \u043C\u0430\u043B\u043E, \u043D\u0443\u0436\u0435\u043D
        \u0435\u0449\u0451 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043A\u043E\u0434."
    _answers:
    - _addReputation: 0
      inputText: "\u0427\u0442\u043E \u0432\u044B \u0435\u043C\u0443 \u0433\u043E\u0432\u043E\u0440\u0438\u043B\u0438?"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 1
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u0440\u0434\u0436\u0438\u043D\u0438\u044F \u041F\u043E\u0442\u0442\u0441"
      inputText: "\u0418 \u043E\u043D \u043E\u0442\u0432\u0435\u0442\u0438\u043B:
        \"\u041E\u0431\u043D\u0430\u0440\u0443\u0436\u0435\u043D\u0430 \u0441\u0441\u044B\u043B\u043A\u0430
        \u043D\u0430 \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430. \u0422\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F
        \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u044B\u0439
        \u043A\u043E\u0434 \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u0438\".
        \u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u043E\u0434\u043D\u043E\u0433\u043E
        \u0438\u043C\u0435\u043D\u0438 \u043C\u0430\u043B\u043E, \u043D\u0443\u0436\u0435\u043D
        \u0435\u0449\u0451 \u043A\u0430\u043A\u043E\u0439-\u0442\u043E \u043A\u043E\u0434."
    _answers:
    - _addReputation: 0
      inputText: "\u041F\u043E\u0431\u043B\u0430\u0433\u043E\u0434\u0430\u0440\u0438\u0442\u044C"
