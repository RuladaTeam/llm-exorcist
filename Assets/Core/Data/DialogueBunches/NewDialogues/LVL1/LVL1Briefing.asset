  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u0417\u0430\u0444\u0438\u043A\u0441\u0438\u0440\u043E\u0432\u0430\u043D
        \u0438\u043D\u0446\u0438\u0434\u0435\u043D\u0442. \u0414.\u0410.\u0420.\u0412.\u0418.\u0421.
        \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043B
        \u0434\u043E\u0441\u0442\u0443\u043F \u043A \u043A\u043E\u043C\u043D\u0430\u0442\u0435
        \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u041F\u043E\u0441\u043B\u0435\u0434\u043D\u0438\u0435 \u0442\u0435\u043B\u0435\u043C\u0435\u0442\u0440\u0438\u0447\u0435\u0441\u043A\u0438\u0435
        \u0434\u0430\u043D\u043D\u044B\u0435: \u0432\u043B\u0430\u0434\u0435\u043B\u0435\u0446
        \u0441\u0438\u0441\u0442\u0435\u043C\u044B, \u042D\u043D\u0442\u043E\u043D\u0438
        \u0421\u0442\u0430\u0440\u043A\u043E\u0432, \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0441\u044F
        \u0432 \u0437\u0430\u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u043E\u0439
        \u043C\u0430\u0441\u0442\u0435\u0440\u0441\u043A\u043E\u0439. \u0414\u0432\u0435\u0440\u044C
        \u0432 \u043E\u0441\u043D\u043E\u0432\u043D\u043E\u0439 \u0437\u0430\u043B
        \u043F\u0435\u0440\u0435\u0445\u0432\u0430\u0447\u0435\u043D\u0430 \u0414.\u0410.\u0420.\u0412.\u0418.\u0421.\u043E\u043C. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u0422\u0432\u043E\u044F \u0437\u0430\u0434\u0430\u0447\u0430:
        \u043D\u0430\u0439\u0442\u0438 \u0441\u043F\u043E\u0441\u043E\u0431 \u043E\u0442\u043A\u0440\u044B\u0442\u044C
        \u0434\u0432\u0435\u0440\u044C, \u0437\u0430\u0442\u0435\u043C \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
        \u043F\u0430\u0440\u043E\u043B\u044C \u0434\u043E\u0441\u0442\u0443\u043F\u0430
        \u043A \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u0443 \"\u0424\u0435\u043D\u0438\u043A\u0441\".
        \u0412\u043D\u0438\u043C\u0430\u043D\u0438\u0435: \u043D\u0435 \u043F\u043E\u0432\u0440\u0435\u0434\u0438\u0442\u044C
        \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435 \u043E\u0431\u043E\u0440\u0443\u0434\u043E\u0432\u0430\u043D\u0438\u0435.
        \u0423\u0434\u0430\u0447\u0438, \u044D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442."
    _answers: []
