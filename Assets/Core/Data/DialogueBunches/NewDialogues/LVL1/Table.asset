  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u041E\u0431\u0440\u044B\u0432\u043E\u043A \u0438\u043D\u0441\u0442\u0440\u0443\u043A\u0446\u0438\u0438"
      inputText: "\u0412 \u0441\u043B\u0443\u0447\u0430\u0435 \u0443\u0442\u0435\u0440\u0438
