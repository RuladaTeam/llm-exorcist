  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042F\u0440\u043A\u0430\u044F \u043B\u0438\u0441\u0442\u043E\u0432\u043A\u0430"
      inputText: "\u041A\u0443\u0440\u0441\u044B \u043F\u043E \u0432\u0437\u043B\u043E\u043C\u0443
