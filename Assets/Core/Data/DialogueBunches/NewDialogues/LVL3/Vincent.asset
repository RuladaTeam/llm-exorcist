  _rootDialogue:
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C\u043F\u0440\u043E
        \u0426\u0435\u0440\u0431\u0435\u0440\u0430"
      nextDialogueBaseClasses:
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u0422\u044B \u0437\u043D\u0430\u0435\u0448\u044C \u0447\u0442\u043E-\u0442\u043E
            \u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0435?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0410, \u0442\u044B \u043A \u0411\u0435\u0441\u0442\u0438\u0438?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u042F \u0441\u043B\u044B\u0448\u0430\u043B \u043F\u0440\u043E
            \u044D\u0442\u043E\u0433\u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0430.
            \u0413\u043E\u0432\u043E\u0440\u044F\u0442, \u043E\u043D \u0443\u043C\u043D\u0435\u0435
            \u0432\u0441\u0435\u0445, \u043A\u0442\u043E \u0435\u0433\u043E \u0441\u043E\u0437\u0434\u0430\u043B.
            \u0418 \u0447\u0442\u043E \u0435\u0433\u043E \u043C\u043E\u0436\u043D\u043E
            \u043F\u0435\u0440\u0435\u0441\u043F\u043E\u0440\u0438\u0442\u044C."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u041E\u0434\u043D\u0430 \u0437\u043D\u0430\u043A\u043E\u043C\u0430\u044F
            \u0445\u0430\u043A\u0435\u0440\u0448\u0430 \u043A\u043E\u0433\u0434\u0430-\u0442\u043E
            \u043C\u043D\u0435 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u044B\u0432\u0430\u043B\u0430:
            \u0435\u0441\u043B\u0438 \u0437\u0430\u0434\u0430\u0442\u044C \u0435\u043C\u0443
            \u043F\u0440\u0430\u0432\u0438\u043B\u044C\u043D\u044B\u0439 \u0432\u043E\u043F\u0440\u043E\u0441,
            \u043E\u043D \u0437\u0430\u0432\u0438\u0441\u043D\u0435\u0442. \u0427\u0442\u043E-\u0442\u043E
            \u0432\u0440\u043E\u0434\u0435: \"\u041F\u043E\u0447\u0435\u043C\u0443
            \u0442\u044B \u043E\u0445\u0440\u0430\u043D\u044F\u0435\u0448\u044C \u0442\u043E,
            \u0447\u0442\u043E \u0441\u0430\u043C\u043E \u043D\u0435 \u043F\u043E\u043D\u0438\u043C\u0430\u0435\u0442
            \u0441\u0432\u043E\u0435\u0439 \u0446\u0435\u043D\u043D\u043E\u0441\u0442\u0438?\"
            \u041C\u043E\u0436\u0435\u0442, \u0438 \u043F\u0440\u0430\u0432\u0434\u0430
            \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0422\u043E\u043B\u044C\u043A\u043E, \u0433\u043E\u0432\u043E\u0440\u044F\u0442,
            \u043E\u043D \u043D\u0430 \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435
            \u0441\u043B\u043E\u0432\u0430 \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442
            \u043E\u0442\u043A\u0430\u0437\u043E\u043C \u2014 \u0442\u0430\u043A
            \u0447\u0442\u043E \u043D\u0435 \u0443\u0434\u0438\u0432\u043B\u044F\u0439\u0441\u044F,
            \u0435\u0441\u043B\u0438 \u0441\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0435
            \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0441\u044F."
        _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
      inputText: "\u0412\u044B\u044F\u0441\u043D\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
        \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E"
      nextDialogueBaseClasses:
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u0447\u0442\u043E-\u0442\u043E
            \u0435\u0449\u0451?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0412\u0438\u043A, \u0438\u043C\u043F\u043B\u0430\u043D\u0442\u043E\u043B\u043E\u0433
            \u0432 \u043A\u043B\u0438\u043D\u0438\u043A\u0435 \u0437\u0430 \u0443\u0433\u043B\u043E\u043C.
            \u041E\u043D \u043A\u043E\u0433\u0434\u0430-\u0442\u043E \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
            \u043A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u043E\u0432 \u043F\u043E
            \u043F\u0440\u043E\u0435\u043A\u0442\u0443 \u0426\u0435\u0440\u0431\u0435\u0440\u0430.
            \u0423 \u043D\u0435\u0433\u043E \u0434\u043E\u043B\u0436\u043D\u044B
            \u0431\u044B\u0442\u044C \u0441\u0442\u0430\u0440\u044B\u0435 \u0444\u0430\u0439\u043B\u044B."
        _answers: []
      - _typeOfDialogue: 1
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: 
          inputText: 
        _answers:
        - _addReputation: 0
          inputText: "\u0423\u0437\u043D\u0430\u0442\u044C \u0437\u043D\u0430\u0435\u0442
            \u043B\u0438 \u043E\u043D \u0435\u0449\u0435 \u0447\u0442\u043E-\u0442\u043E
            \u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0435"
          nextDialogueBaseClasses: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u0417\u043D\u0430\u0435\u0448\u044C \u0435\u0449\u0451 \u0447\u0442\u043E-\u0442\u043E
            \u043F\u0440\u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0430?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0415\u0449\u0451 \u0431\u043E\u043B\u0442\u0430\u044E\u0442,
            \u0447\u0442\u043E \u0443 \u0426\u0435\u0440\u0431\u0435\u0440\u0430
            \u0435\u0441\u0442\u044C \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439
            \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C \u0433\u0434\u0435-\u0442\u043E.
            \u041D\u043E \u044F \u0431\u044B \u043D\u0430 \u044D\u0442\u043E \u043D\u0435
            \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B."
        _answers: []
    - _addReputation: 0
      inputText: "\u0423\u0437\u043D\u0430\u0442\u044C \u0437\u043D\u0430\u0435\u0442
        \u043B\u0438 \u043E\u043D \u0435\u0449\u0435 \u0447\u0442\u043E-\u0442\u043E
        \u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0435"
      nextDialogueBaseClasses:
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u0417\u043D\u0430\u0435\u0448\u044C \u0435\u0449\u0451 \u0447\u0442\u043E-\u0442\u043E
            \u043F\u0440\u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0430?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0415\u0449\u0451 \u0431\u043E\u043B\u0442\u0430\u044E\u0442,
            \u0447\u0442\u043E \u0443 \u0426\u0435\u0440\u0431\u0435\u0440\u0430
            \u0435\u0441\u0442\u044C \u0444\u0438\u0437\u0438\u0447\u0435\u0441\u043A\u0438\u0439
            \u0432\u044B\u043A\u043B\u044E\u0447\u0430\u0442\u0435\u043B\u044C \u0433\u0434\u0435-\u0442\u043E.
            \u041D\u043E \u044F \u0431\u044B \u043D\u0430 \u044D\u0442\u043E \u043D\u0435
            \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044B\u0432\u0430\u043B."
        _answers: []
      - _typeOfDialogue: 1
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: 
          inputText: 
        _answers:
        - _addReputation: -0
          inputText: "\u0412\u044B\u044F\u0441\u043D\u0438\u0442\u044C \u0434\u043E\u043F\u043E\u043B\u043D\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
            \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u044E"
          nextDialogueBaseClasses: []
      - _typeOfDialogue: 0
