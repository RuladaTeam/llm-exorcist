        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E \u0447\u0442\u043E-\u0442\u043E
            \u0435\u0449\u0451?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0412\u0438\u043D\u0446\u0435\u043D\u0442"
          inputText: "\u0412\u0438\u043A, \u0438\u043C\u043F\u043B\u0430\u043D\u0442\u043E\u043B\u043E\u0433
            \u0432 \u043A\u043B\u0438\u043D\u0438\u043A\u0435 \u0437\u0430 \u0443\u0433\u043B\u043E\u043C.
            \u041E\u043D \u043A\u043E\u0433\u0434\u0430-\u0442\u043E \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
            \u043A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u043E\u0432 \u043F\u043E
            \u043F\u0440\u043E\u0435\u043A\u0442\u0443 \u0426\u0435\u0440\u0431\u0435\u0440\u0430.
            \u0423 \u043D\u0435\u0433\u043E \u0434\u043E\u043B\u0436\u043D\u044B
            \u0431\u044B\u0442\u044C \u0441\u0442\u0430\u0440\u044B\u0435 \u0444\u0430\u0439\u043B\u044B."
