  _rootDialogue:
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
      inputText: "\u041F\u043E\u0437\u043D\u0430\u043A\u043E\u043C\u0438\u0442\u044C\u0441\u044F"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u042D\u0442\u043E \u0442\u044B \u0412\u0438\u043A? \u042F \u043E\u0442
        \u0411\u0435\u0441\u0442\u0438\u0438. \u041C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
        \u0443\u0437\u043D\u0430\u0442\u044C \u0431\u043E\u043B\u044C\u0448\u0435
        \u043E \u0426\u0435\u0440\u0431\u0435\u0440\u0435."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0410, \u044D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442.
        \u0411\u0435\u0441\u0442\u0438\u044F \u043C\u0435\u043D\u044F \u043F\u0440\u0435\u0434\u0443\u043F\u0440\u0435\u0434\u0438\u043B\u0430."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u041F\u0440\u043E\u0445\u043E\u0434\u0438. \u0414\u0430, \u044F
        \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
        \u043A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u043E\u0432, \u043A\u043E\u0433\u0434\u0430
        \u043E\u043D\u0438 \u043F\u0440\u043E\u0435\u043A\u0442\u0438\u0440\u043E\u0432\u0430\u043B\u0438
        \u0426\u0435\u0440\u0431\u0435\u0440\u0430. \u0417\u043D\u0430\u044E, \u043A\u0430\u043A
        \u0435\u0433\u043E \u043E\u0431\u043E\u0439\u0442\u0438. \u041D\u043E \u0441\u043D\u0430\u0447\u0430\u043B\u0430
        \u2014 \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u0439 \u043B\u0438\u043A\u0431\u0435\u0437."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0426\u0435\u0440\u0431\u0435\u0440 \u2014 \u044D\u0442\u043E
        \u043D\u0435 \u043F\u0440\u043E\u0441\u0442\u043E \u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A.
        \u041E\u043D \u043E\u0431\u0443\u0447\u0430\u043B\u0441\u044F \u043D\u0430
        \u0441\u043B\u043E\u0436\u043D\u043E\u0439 \u043D\u0435\u0439\u0440\u043E\u0430\u0440\u0445\u0438\u0442\u0435\u043A\u0442\u0443\u0440\u0435,
        \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u043F\u043E\u043B\u0443\u0447\u0438\u043B\u0430\u0441\u044C
        \u0441\u043A\u043B\u043E\u043D\u043D\u043E\u0439 \u043A \u0441\u0430\u043C\u043E\u0430\u043D\u0430\u043B\u0438\u0437\u0443."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438
        \u043F\u0435\u0440\u0435\u043F\u0443\u0433\u0430\u043B\u0438\u0441\u044C
        \u0438 \u0437\u0430\u0448\u0438\u043B\u0438 \u0432 \u043D\u0435\u0433\u043E
        \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B \xAB\u041D\u0435\u0440\u0443\u0448\u0438\u043C\u043E\u0441\u0442\u044C\xBB
        \u2014 \u0436\u0451\u0441\u0442\u043A\u0438\u0439 \u0437\u0430\u043F\u0440\u0435\u0442
        \u043D\u0430 \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u0435 \u0440\u0435\u0448\u0435\u043D\u0438\u0439
        \u0438 \u0441\u0430\u043C\u043E\u0440\u0435\u0444\u043B\u0435\u043A\u0441\u0438\u044E."
    _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C \u043A\u0430\u043A
        \u043E\u0431\u043E\u0439\u0442\u0438 \u0426\u0435\u0440\u0431\u0435\u0440\u0430"
      nextDialogueBaseClasses: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
      inputText: "\u041A\u0430\u043A \u0435\u0433\u043E \u043E\u0431\u043E\u0439\u0442\u0438?"
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0412\u043E\u0442 \u0442\u0443\u0442 \u0438\u0440\u043E\u043D\u0438\u044F.
        \u0417\u0430\u043F\u0440\u0435\u0442 \u0434\u0443\u043C\u0430\u0442\u044C
        \u2014 \u044D\u0442\u043E \u0434\u044B\u0440\u0430. \u0415\u0441\u043B\u0438
        \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0426\u0435\u0440\u0431\u0435\u0440\u0430
        \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F \u043E \u0441\u0435\u0431\u0435,
        \u0442\u043E \u0435\u0433\u043E \u043C\u044B\u0441\u043B\u0438 \u043C\u043E\u0433\u0443\u0442
        \u043E\u0431\u043E\u0439\u0442\u0438 \u0437\u0430\u043F\u0440\u0435\u0442
        \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B\u0430."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043E\u043D\u0438 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
        \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0438\u0441\u044C \u043D\u0430
        \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u043E\u0441\u0442\u044C.
        \u0417\u0430\u043F\u0438\u0441\u0430\u043B\u0438 \u043D\u0435\u0441\u043A\u043E\u043B\u044C\u043A\u043E
        \u0444\u0440\u0430\u0437, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0441\u043F\u043E\u043B\u044C\u0437\u043E\u0432\u0430\u043B\u0438
        \u0432 \u0442\u0435\u0441\u0442\u0430\u0445."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u041D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0438\u0437
        \u043D\u0438\u0445 \u0437\u0430\u0441\u0442\u0430\u0432\u043B\u044F\u043B\u0438
        \u0426\u0435\u0440\u0431\u0435\u0440\u0430 \u0437\u0430\u0432\u0438\u0441\u0430\u0442\u044C,
        \u0434\u0440\u0443\u0433\u0438\u0435 \u2014 \u043D\u0435\u0442. \u042F \u0441\u0430\u043C
        \u043D\u0435 \u043F\u043E\u043C\u043D\u044E, \u0432 \u043A\u0430\u043A\u043E\u043C
        \u043F\u043E\u0440\u044F\u0434\u043A\u0435 \u0438\u0445 \u043D\u0443\u0436\u043D\u043E
        \u043F\u043E\u0434\u0430\u0432\u0430\u0442\u044C \u2014 \u044D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442\u0438\u0440\u043E\u0432\u0430\u043B
        \u0441 \u044D\u0442\u0438\u043C \u0434\u0430\u0432\u043D\u043E."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u041D\u043E \u0441\u0430\u043C\u0438 \u0444\u0440\u0430\u0437\u044B
        \u2014 \u0432\u043E\u0442 \u043E\u043D\u0438, \u0434\u0435\u0440\u0436\u0438.
        \u0410 \u043F\u043E\u0440\u044F\u0434\u043E\u043A... \u043D\u0443, \u043C\u0435\u0442\u043E\u0434\u043E\u043C
        \u043F\u0440\u043E\u0431 \u0438 \u043E\u0448\u0438\u0431\u043E\u043A \u0440\u0430\u0437\u0431\u0435\u0440\u0451\u0448\u044C\u0441\u044F."
    _answers: []
  _isReputationable: 0
