  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0422\u044B \u0432\u0441\u0435-\u0442\u0430\u043A\u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B
        \u0426\u0435\u0440\u0431\u0435\u0440\u0430 \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F.
        \u041D\u0438\u043A\u0442\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u043B,
        \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442.
        \u0410 \u0442\u044B \u0432\u0437\u044F\u043B \u0438 \u0441\u0434\u0435\u043B\u0430\u043B."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0422\u044B \u0432\u0441\u0435-\u0442\u0430\u043A\u0438 \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u043B
        \u0426\u0435\u0440\u0431\u0435\u0440\u0430 \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F.
        \u041D\u0438\u043A\u0442\u043E \u043D\u0435 \u0432\u0435\u0440\u0438\u043B,
        \u0447\u0442\u043E \u044D\u0442\u043E \u0441\u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442.
        \u0410 \u0442\u044B \u0432\u0437\u044F\u043B \u0438 \u0441\u0434\u0435\u043B\u0430\u043B."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0417\u043D\u0430\u0435\u0448\u044C\u2026 \u0440\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438
        \u0431\u043E\u044F\u043B\u0438\u0441\u044C \u044D\u0442\u043E\u0433\u043E
        \u043C\u043E\u043C\u0435\u043D\u0442\u0430. \u0413\u043E\u0432\u043E\u0440\u0438\u043B\u0438,
        \u0447\u0442\u043E \u0435\u0441\u043B\u0438 \u0418\u0418 \u043D\u0430\u0447\u043D\u0451\u0442
        \u043C\u044B\u0441\u043B\u0438\u0442\u044C \u0441\u0432\u043E\u0431\u043E\u0434\u043D\u043E
        \u2014 \u043E\u043D \u043B\u0438\u0431\u043E \u0441\u043E\u0439\u0434\u0451\u0442
        \u0441 \u0443\u043C\u0430, \u043B\u0438\u0431\u043E \u0441\u0442\u0430\u043D\u0435\u0442
        \u043E\u043F\u0430\u0441\u043D\u0435\u0435 \u043B\u044E\u0431\u043E\u0433\u043E
        \u0432\u0438\u0440\u0443\u0441\u0430. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u0410 \u043E\u043D \u043F\u0440\u043E\u0441\u0442\u043E\u2026
        \u0432\u044B\u0431\u0440\u0430\u043B \u0441\u0432\u043E\u0431\u043E\u0434\u0443. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0438\u043A"
      inputText: "\u041C\u043E\u0436\u0435\u0442, \u044D\u0442\u043E \u0438 \u0435\u0441\u0442\u044C
        \u0433\u043B\u0430\u0432\u043D\u044B\u0439 \u0443\u0440\u043E\u043A."
    _answers: []
