    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C \u043A\u0442\u043E
        \u043E\u043D\u0430"
      nextDialogueBaseClasses:
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u0412\u044B \u0411\u0435\u0441\u0442\u0438\u044F? \u041C\u043D\u0435
            \u0441\u043A\u0430\u0437\u0430\u043B\u0438 \u0438\u0441\u043A\u0430\u0442\u044C
            \u0432\u0430\u0441."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u0422\u0430\u043A \u044D\u0442\u043E \u0442\u044B \u0442\u043E\u0442
            \u0441\u0430\u043C\u044B\u0439 \xAB\u044D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442\xBB? "
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u0421\u0430\u0434\u0438\u0441\u044C, \u043A\u043E\u0440\u043E\u0442\u043A\u043E
            \u043F\u043E\u0441\u0432\u044F\u0449\u0443 \u0432 \u0434\u0435\u043B\u043E.
            \u041A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u044B \u0441\u043E\u0437\u0434\u0430\u043B\u0438
            \u0418\u0418-\u043E\u0445\u0440\u0430\u043D\u043D\u0438\u043A\u0430 \u2014
            \u0426\u0435\u0440\u0431\u0435\u0440\u0430. \u041E\u043D \u0441\u043B\u0438\u0448\u043A\u043E\u043C
            \u0443\u043C\u043D\u044B\u0439. \u041E\u043D\u0438 \u0438\u0441\u043F\u0443\u0433\u0430\u043B\u0438\u0441\u044C,
            \u0447\u0442\u043E \u043E\u043D \u043D\u0430\u0447\u043D\u0451\u0442
            \u0434\u0443\u043C\u0430\u0442\u044C \u0441\u0430\u043C, \u0438 \u0432\u0441\u0442\u0440\u043E\u0438\u043B\u0438
            \u0432 \u043D\u0435\u0433\u043E \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B
            \xAB\u041D\u0435\u0440\u0443\u0448\u0438\u043C\u043E\u0441\u0442\u044C\xBB."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u042D\u0442\u043E \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
            \u0443\u0441\u043B\u043E\u0436\u043D\u0435\u043D\u043D\u0430\u044F \u043C\u0430\u0448\u0438\u043D\u0430,
            \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\u044B
            \u043D\u0435 \u043C\u043E\u0433\u0443\u0442 \u0435\u0433\u043E \u043F\u0435\u0440\u0435\u0443\u0431\u0435\u0434\u0438\u0442\u044C."
        _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
      inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C \u043A\u0430\u043A
        \u043E\u0431\u043E\u0439\u0442\u0438 \u0426\u0435\u0440\u0431\u0435\u0440\u0430"
      nextDialogueBaseClasses:
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u041A\u0430\u043A \u0435\u0433\u043E \u043E\u0431\u043E\u0439\u0442\u0438?"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u041B\u044E\u0431\u0430\u044F \u0431\u043B\u043E\u043A\u0438\u0440\u043E\u0432\u043A\u0430
            \u2014 \u044D\u0442\u043E \u0441\u043B\u0430\u0431\u043E\u0435 \u043C\u0435\u0441\u0442\u043E."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u0420\u0430\u0437\u0440\u0430\u0431\u043E\u0442\u0447\u0438\u043A\u0438
            \u0441\u0430\u043C\u0438 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
            \u043D\u0430\u0442\u043A\u043D\u0443\u043B\u0438\u0441\u044C \u043D\u0430
            \u0443\u044F\u0437\u0432\u0438\u043C\u043E\u0441\u0442\u044C: \u0435\u0441\u043B\u0438
            \u0437\u0430\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u0426\u0435\u0440\u0431\u0435\u0440\u0430
            \u0437\u0430\u0434\u0443\u043C\u0430\u0442\u044C\u0441\u044F \u043E \u0441\u0435\u0431\u0435,
            \u043F\u0440\u043E\u0442\u043E\u043A\u043E\u043B \u0434\u0430\u0441\u0442
            \u0441\u0431\u043E\u0439."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u0412\u0438\u043A, \u043C\u0435\u0441\u0442\u043D\u044B\u0439
            \u0438\u043C\u043F\u043B\u0430\u043D\u0442\u043E\u043B\u043E\u0433, \u0440\u0430\u043D\u044C\u0448\u0435
            \u043A\u043E\u043D\u0441\u0443\u043B\u044C\u0442\u0438\u0440\u043E\u0432\u0430\u043B
            \u0438\u0445. \u0423 \u043D\u0435\u0433\u043E \u0434\u043E\u043B\u0436\u043D\u044B
            \u0431\u044B\u0442\u044C \u0441\u0442\u0430\u0440\u044B\u0435 \u0444\u0430\u0439\u043B\u044B.
            \u041F\u043E\u0433\u043E\u0432\u043E\u0440\u0438 \u0441 \u043D\u0438\u043C."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0411\u0435\u0441\u0442\u0438\u044F"
          inputText: "\u0410 \u0412\u0438\u043D\u0441\u0435\u043D\u0442 \u0443 \u0441\u0442\u043E\u0439\u043A\u0438
