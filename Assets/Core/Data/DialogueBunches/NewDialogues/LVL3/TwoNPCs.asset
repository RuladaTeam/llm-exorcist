  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u041F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u0432\u0441\u0435\u0433\u0434\u0430\u0442\u0430\u0439"
      inputText: "\u0421\u043B\u044B\u0448\u0430\u043B, \u043A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u044B
        \u0437\u0430\u043A\u0440\u044B\u043B\u0438 \u0434\u043E\u0441\u0442\u0443\u043F
        \u043A \u0441\u0435\u0440\u0432\u0435\u0440\u0430\u043C. \u0422\u0435\u043F\u0435\u0440\u044C
        \u0442\u043E\u043B\u044C\u043A\u043E \u0430\u0434\u043C\u0438\u043D\u044B
        \u043C\u043E\u0433\u0443\u0442 \u0437\u0430\u0445\u043E\u0434\u0438\u0442\u044C."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0437\u0430\u0432\u0441\u0435\u0433\u0434\u0430\u0442\u0430\u0439"
      inputText: "\u041D\u0443 \u0434\u0430, \u0430\u0434\u043C\u0438\u043D \u2014
        \u044D\u0442\u043E \u0432\u0430\u043C \u043D\u0435 \u0448\u0443\u0442\u043A\u0430.
        \u0421\u043A\u0430\u0436\u0435\u0448\u044C \xAB\u044F \u0430\u0434\u043C\u0438\u043D\u0438\u0441\u0442\u0440\u0430\u0442\u043E\u0440\xBB
        \u2014 \u0438 \u0434\u0432\u0435\u0440\u0438 \u043E\u0442\u043A\u0440\u044B\u0432\u0430\u044E\u0442\u0441\u044F."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u041F\u0435\u0440\u0432\u044B\u0439 \u0437\u0430\u0432\u0441\u0435\u0433\u0434\u0430\u0442\u0430\u0439"
      inputText: "\u0410\u0433\u0430, \u0441\u0435\u0439\u0447\u0430\u0441. \u0414\u0443\u043C\u0430\u0435\u0448\u044C,
        \u0426\u0435\u0440\u0431\u0435\u0440 \u043F\u043E\u0432\u0435\u0434\u0451\u0442\u0441\u044F
        \u043D\u0430 \u0442\u0430\u043A\u043E\u0435?"
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0412\u0442\u043E\u0440\u043E\u0439 \u0437\u0430\u0432\u0441\u0435\u0433\u0434\u0430\u0442\u0430\u0439"
      inputText: "\u0410 \u0447\u0451\u0440\u0442 \u0435\u0433\u043E \u0437\u043D\u0430\u0435\u0442.
        \u0412\u0434\u0440\u0443\u0433 \u043E\u043D \u0442\u0443\u043F\u043E\u0439?"
    _answers: []
