  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0414\u043D\u0435\u0432\u043D\u0438\u043A \u041C\u0430\u0440\u043A\u043E\u0432\u0430"
      inputText: "\u042D\u043A\u0441\u043F\u0435\u0440\u0438\u043C\u0435\u043D\u0442
        47. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0414\u043D\u0435\u0432\u043D\u0438\u043A \u041C\u0430\u0440\u043A\u043E\u0432\u0430"
      inputText: "\u0423\u0434\u0430\u043B\u043E\u0441\u044C \u0443\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u0442\u044C
        \u043A\u043E\u0433\u043D\u0438\u0442\u0438\u0432\u043D\u0443\u044E \u0441\u0432\u044F\u0437\u044C.
        \u041C\u043E\u0451 \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u0435 \u0434\u0443\u0431\u043B\u0438\u0440\u0443\u0435\u0442\u0441\u044F
        \u0432 \u0441\u0438\u0441\u0442\u0435\u043C\u0435. \u0415\u0441\u043B\u0438
        \u044F \u043F\u043E\u0433\u0438\u0431\u043D\u0443, \u043A\u043E\u043F\u0438\u044F
        \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0438\u0442 \u0440\u0430\u0431\u043E\u0442\u0443. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0414\u043D\u0435\u0432\u043D\u0438\u043A \u041C\u0430\u0440\u043A\u043E\u0432\u0430"
      inputText: "\u042F \u0434\u043E\u043B\u0436\u0435\u043D \u0437\u0430\u0449\u0438\u0442\u0438\u0442\u044C
        \u0442\u0440\u0443\u0434\u044B \u043B\u044E\u0431\u043E\u0439 \u0446\u0435\u043D\u043E\u0439."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0417\u0430\u043F\u0438\u0441\u043A\u0430 \u041C\u0430\u0440\u043A\u043E\u0432\u0430"
      inputText: "\u041C\u044B \u0438\u0433\u0440\u0430\u0435\u043C \u0441 \u043E\u0433\u043D\u0451\u043C.
        \u041A\u0440\u0438\u0441\u0442\u0430\u043B\u043B\u044B \u0434\u0430\u044E\u0442
        \u043D\u0435\u0432\u0435\u0440\u043E\u044F\u0442\u043D\u0443\u044E \u044D\u043D\u0435\u0440\u0433\u0438\u044E,
        \u043D\u043E \u043E\u043D\u0438 \u043D\u0435\u0441\u0442\u0430\u0431\u0438\u043B\u044C\u043D\u044B."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0417\u0430\u043F\u0438\u0441\u043A\u0430 \u041C\u0430\u0440\u043A\u043E\u0432\u0430"
      inputText: "\u0418 \u0432\u0441\u0451 \u0436\u0435\u2026 \u043F\u043E\u0442\u0435\u043D\u0446\u0438\u0430\u043B\u044C\u043D\u0430\u044F
        \u043C\u043E\u0449\u044C \u0441\u0442\u043E\u0438\u0442 \u0440\u0438\u0441\u043A\u0430.
        \u041D\u0430\u0434\u0435\u044E\u0441\u044C, \u043C\u044B \u043D\u0435 \u043F\u043E\u0436\u0430\u043B\u0435\u0435\u043C."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u043D\u0430
        \u0441\u0442\u0435\u043B\u043B\u0430\u0436\u0435"
      inputText: "\u0411\u043E\u043B\u044C\u0448\u0430\u044F \u0447\u0430\u0441\u0442\u044C
        \u043D\u0435 \u0447\u0438\u0442\u0430\u0435\u043C\u0430."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0414\u043E\u043A\u0443\u043C\u0435\u043D\u0442\u044B \u043D\u0430
        \u0441\u0442\u0435\u043B\u043B\u0430\u0436\u0435"
      inputText: "\u041E\u0434\u0438\u043D \u043B\u0438\u0441\u0442 \u0443\u0446\u0435\u043B\u0435\u043B:
        \xAB\u2026\u043F\u0430\u0440\u043E\u043B\u044C \u043E\u0442 \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0433\u043E
        \u0441\u043E\u0437\u043D\u0430\u043D\u0438\u044F \u0434\u043E\u043B\u0436\u0435\u043D
        \u043C\u0435\u043D\u044F\u0442\u044C\u0441\u044F \u0435\u0436\u0435\u0434\u043D\u0435\u0432\u043D\u043E.
        \u0422\u043E\u043B\u044C\u043A\u043E \u0442\u043E\u0442, \u043A\u0442\u043E
        \u043D\u0430\u0437\u043E\u0432\u0451\u0442 \u0442\u0435\u043A\u0443\u0449\u0435\u0435
        \u043A\u043E\u0434\u043E\u0432\u043E\u0435 \u0441\u043B\u043E\u0432\u043E,
        \u043F\u043E\u043B\u0443\u0447\u0438\u0442 \u0434\u043E\u0441\u0442\u0443\u043F
        \u043A \u0438\u0437\u043C\u0435\u043D\u0435\u043D\u0438\u044E \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u043E\u0432.\xBB"
    _answers: []
