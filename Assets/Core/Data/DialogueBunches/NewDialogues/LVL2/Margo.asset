        _simplePhrase:
          _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
          inputText: "\u0412\u044B \u0437\u0434\u0435\u0441\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442\u0435?"
