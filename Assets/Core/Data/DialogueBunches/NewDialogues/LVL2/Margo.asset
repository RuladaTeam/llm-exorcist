            _symbolTime: 0.05
            _simplePhrase:
              _inputName: "\u042D\u043A\u0437\u043E\u0440\u0446\u0438\u0441\u0442"
              inputText: "\u0427\u0442\u043E \u0442\u0443\u0442 \u0441\u043B\u0443\u0447\u0438\u043B\u043E\u0441\u044C?"
            _answers: []
          - _typeOfDialogue: 0
            _symbolTime: 0.05
            _simplePhrase:
              _inputName: "\u041C\u0430\u0440\u0433\u043E"
              inputText: "\u0423\u0447\u0451\u043D\u044B\u0435 \u0438\u0433\u0440\u0430\u043B\u0438\u0441\u044C
                \u0441 \u043F\u0440\u0438\u0448\u0435\u043B\u044C\u0447\u0435\u0441\u043A\u043E\u0439
                \u0442\u0435\u0445\u043D\u0438\u043A\u043E\u0439. \u041C\u0430\u0440\u043A\u043E\u0432\u2026
                \u0434\u0443\u043C\u0430\u043B, \u0447\u0442\u043E \u0441\u043C\u043E\u0436\u0435\u0442
                \u0435\u0451 \u043A\u043E\u043D\u0442\u0440\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C."
            _answers: []
          - _typeOfDialogue: 0
            _symbolTime: 0.05
            _simplePhrase:
              _inputName: "\u041C\u0430\u0440\u0433\u043E"
              inputText: "\u0412 \u0438\u0442\u043E\u0433\u0435 \u2013 \u0432\u0437\u0440\u044B\u0432.
                \u041C\u043D\u043E\u0433\u0438\u0435 \u043F\u043E\u0433\u0438\u0431\u043B\u0438.
                \u041C\u0430\u0440\u043A\u043E\u0432 \u0442\u043E\u0436\u0435\u2026
                \u043D\u043E \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u0435\u0433\u043E
                \u0446\u0438\u0444\u0440\u043E\u0432\u043E\u0439 \u0441\u043B\u0435\u0434
                \u043E\u0441\u0442\u0430\u043B\u0441\u044F."
            _answers: []
