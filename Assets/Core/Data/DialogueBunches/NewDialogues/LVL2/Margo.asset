          inputText: "\u042F \u041C\u0430\u0440\u0433\u043E."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u041C\u0430\u0440\u0433\u043E"
          inputText: "\u0421\u043B\u0435\u0436\u0443, \u0447\u0442\u043E\u0431\u044B
            \u043C\u0430\u0440\u043E\u0434\u0451\u0440\u044B \u043D\u0435 \u043B\u0435\u0437\u043B\u0438.
            \u041A\u043E\u0440\u043F\u043E\u0440\u0430\u0442\u044B \u0431\u0440\u043E\u0441\u0438\u043B\u0438
            \u043E\u0431\u044A\u0435\u043A\u0442, \u0430 \u0432\u0435\u0449\u0438\u0447\u043A\u0438
            \u0446\u0435\u043D\u043D\u044B\u0435."
        _answers: []
      - _typeOfDialogue: 1
        _symbolTime: 0
        _simplePhrase:
          _inputName: 
          inputText: 
        _answers:
        - _addReputation: 0
          inputText: "\u0421\u043F\u0440\u043E\u0441\u0438\u0442\u044C \u0447\u0442\u043E
