                \xAB\u041E\u0442\u043A\u0440\u043E\u0439!\xBB \u2013 \u0430 \u043E\u043D:
                \xAB\u041D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E
                \u043F\u043E\u043B\u043D\u043E\u043C\u043E\u0447\u0438\u0439\xBB."
            _answers: []
          - _typeOfDialogue: 0
            _symbolTime: 0.05
            _simplePhrase:
              _inputName: "\u041C\u0430\u0440\u0433\u043E"
              inputText: "\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u044F \u0441\u043A\u0430\u0437\u0430\u043B\u0430:
                \xAB\u041C\u0430\u0440\u043A\u043E\u0432, \u044F \u0437\u0434\u0435\u0441\u044C,
                \u0447\u0442\u043E\u0431\u044B \u0441\u043E\u0445\u0440\u0430\u043D\u0438\u0442\u044C
                \u043D\u0430\u0441\u043B\u0435\u0434\u0438\u0435, \u0430 \u043D\u0435
                \u0443\u043A\u0440\u0430\u0441\u0442\u044C \u0435\u0433\u043E\xBB.\r\n"
            _answers: []
          - _typeOfDialogue: 0
            _symbolTime: 0.05
            _simplePhrase:
              _inputName: "\u041C\u0430\u0440\u0433\u043E"
              inputText: "\u0414\u0432\u0435\u0440\u044C \u0437\u0430\u0441\u043A\u0440\u0435\u0436\u0435\u0442\u0430\u043B\u0430
                \u0431\u0443\u0434\u0442\u043E \u043F\u044B\u0442\u0430\u043B\u0430\u0441\u044C
                \u043E\u0442\u043A\u0440\u044B\u0442\u044C\u0441\u044F, \u043D\u043E
