      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u0417\u0434\u0440\u0430\u0432\u0441\u0442\u0432\u0443\u0439\u0442\u0435,
            \u044F \u0420\u043E\u0431\u0438\u043D"
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u0414\u0430 \u0438\u0449\u0443, \u043C\u043E\u044E \u0441\u0435\u0441\u0442\u0440\u0443."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u041E\u043D\u0430 \u0437\u0434\u0435\u0441\u044C \u0440\u0430\u0431\u043E\u0442\u0430\u043B\u0430.
            \u0412 \u0434\u0435\u043D\u044C \u0430\u0432\u0430\u0440\u0438\u0438
            \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u0432 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u0438
            \u0441 \u041C\u0430\u0440\u043A\u043E\u0432\u044B\u043C."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u041C\u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B\u0438,
            \u0447\u0442\u043E \u043E\u043D\u0430 \u043F\u043E\u0433\u0438\u0431\u043B\u0430.
            \u041D\u043E \u044F \u043D\u0435 \u0432\u0435\u0440\u044E, \u0447\u0442\u043E
            \u044D\u0442\u043E \u0431\u044B\u043B\u0430 \u043F\u0440\u043E\u0441\u0442\u043E
            \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E\u0441\u0442\u044C."
        _answers: []
  - _typeOfDialogue: 1
    _symbolTime: 0
    _simplePhrase:
      _inputName: 
      inputText: 
    _answers:
    - _addReputation: 0
