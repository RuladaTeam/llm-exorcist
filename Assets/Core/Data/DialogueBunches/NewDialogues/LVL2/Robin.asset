        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u0427\u0442\u043E \u043E\u043D \u0437\u0430\u0449\u0438\u0449\u0430\u043B?
            \u041F\u043E\u0447\u0435\u043C\u0443 \u043C\u043E\u044F \u0441\u0435\u0441\u0442\u0440\u0430
