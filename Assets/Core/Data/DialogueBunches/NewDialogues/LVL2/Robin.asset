      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u041E\u043D \u043F\u0438\u0441\u0430\u043B: \xAB\u0415\u0441\u043B\u0438
