      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u041D\u0435\u043C\u043D\u043E\u0433\u043E. \u041E\u0431\u0440\u044B\u0432\u043A\u0438
            \u043B\u043E\u0433\u043E\u0432."
        _answers: []
      - _typeOfDialogue: 0
        _symbolTime: 0.05
        _simplePhrase:
          _inputName: "\u0420\u043E\u0431\u0438\u043D"
          inputText: "\u041C\u0430\u0440\u043A\u043E\u0432 \u043F\u0435\u0440\u0435\u0434
            \u0430\u0432\u0430\u0440\u0438\u0435\u0439 \u043F\u0438\u0441\u0430\u043B:
