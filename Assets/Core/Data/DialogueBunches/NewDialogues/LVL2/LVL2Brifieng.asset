  _rootDialogue:
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u041E\u043A\u0435\u0430\u043D\u0430\u0440\u0438\u0443\u043C \xAB\u0413\u043B\u0443\u0431\u0438\u043D\u0430\xBB. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u041F\u043E \u043D\u0435\u043A\u043E\u0442\u043E\u0440\u044B\u043C
        \u0434\u0430\u043D\u043D\u044B\u043C, \u044D\u0442\u043E \u0431\u044B\u043B\u043E
        \u043F\u0440\u0438\u043A\u0440\u044B\u0442\u0438\u0435 \u0434\u043B\u044F
        \u0438\u0441\u0441\u043B\u0435\u0434\u043E\u0432\u0430\u0442\u0435\u043B\u044C\u0441\u043A\u043E\u0433\u043E
        \u0446\u0435\u043D\u0442\u0440\u0430 \xAB\u041A\u043E\u0432\u0447\u0435\u0433\xBB,
        \u0438\u0437\u0443\u0447\u0430\u0432\u0448\u0435\u0433\u043E \u0430\u0440\u0442\u0435\u0444\u0430\u043A\u0442\u044B
        \u043F\u0440\u0438\u0448\u0435\u043B\u044C\u0446\u0435\u0432. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u0417\u0430\u043A\u0440\u044B\u0442 10 \u043B\u0435\u0442 \u043D\u0430\u0437\u0430\u0434
        \u043F\u043E\u0441\u043B\u0435 \u0430\u0432\u0430\u0440\u0438\u0438. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u041F\u043E\u0441\u043B\u0435 \u0433\u0438\u0431\u0435\u043B\u0438
        \u0432\u0435\u0434\u0443\u0449\u0435\u0433\u043E \u0443\u0447\u0451\u043D\u043E\u0433\u043E
        \u043F\u0440\u043E\u0435\u043A\u0442 \u0441\u0432\u0435\u0440\u043D\u0443\u043B\u0438.
        \u0421 \u0442\u0435\u0445 \u043F\u043E\u0440 \u0441\u0438\u0441\u0442\u0435\u043C\u0430
        \u0444\u0438\u043A\u0441\u0438\u0440\u0443\u0435\u0442 \u0430\u043D\u043E\u043C\u0430\u043B\u044C\u043D\u0443\u044E
        \u0430\u043A\u0442\u0438\u0432\u043D\u043E\u0441\u0442\u044C. "
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0411\u0440\u0438\u0444\u0438\u043D\u0433"
      inputText: "\u0418\u0437\u0433\u043E\u043D\u0438\u0442\u0435 \u043F\u0440\u0438\u0437\u0440\u0430\u043A\u0430,
        \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u0435 \u0440\u0443\u043D\u0443."
    _answers: []
