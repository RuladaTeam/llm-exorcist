  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0420\u0430\u0437\u0431\u0438\u0442\u044B\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
        \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B"
      inputText: "\u041D\u0430 \u043A\u043E\u0440\u043F\u0443\u0441\u0435 \u043B\u043E\u0433\u043E\u0442\u0438\u043F
        \xAB\u041A\u043E\u0432\u0447\u0435\u0433\xBB."
    _answers: []
  - _typeOfDialogue: 0
    _symbolTime: 0.05
    _simplePhrase:
      _inputName: "\u0420\u0430\u0437\u0431\u0438\u0442\u044B\u0439 \u0438\u043D\u0444\u043E\u0440\u043C\u0430\u0446\u0438\u043E\u043D\u043D\u044B\u0439
        \u0442\u0435\u0440\u043C\u0438\u043D\u0430\u043B"
      inputText: "\u041D\u0435 \u0440\u0430\u0431\u043E\u0442\u0430\u0435\u0442.
        \u041D\u0430\u0434\u043F\u0438\u0441\u044C \u043D\u0430 \u043B\u0438\u0441\u0442\u043E\u0447\u043A\u0435
        \u0441\u0431\u043E\u043A\u0443: \xAB\u0414\u043B\u044F \u0434\u043E\u0441\u0442\u0443\u043F\u0430
        \u0432 \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u0438\u044E
        \u0442\u0440\u0435\u0431\u0443\u0435\u0442\u0441\u044F \u0430\u0432\u0442\u043E\u0440\u0438\u0437\u0430\u0446\u0438\u044F,
        \u043F\u0430\u0440\u043E\u043B\u044C \u043C\u043E\u0436\u043D\u043E \u043F\u043E\u043B\u0443\u0447\u0438\u0442\u044C
        \u0443 \u0434\u0435\u0436\u0443\u0440\u043D\u043E\u0433\u043E \u0441\u043E\u0442\u0440\u0443\u0434\u043D\u0438\u043A\u0430
        \u0438\u043B\u0438 \u0432 \u043A\u043E\u043D\u0441\u043E\u043B\u0438, \u0432
        \u043D\u0435\u0435 \u043D\u0435\u0434\u0430\u0432\u043D\u043E \u0434\u043E\u0431\u0430\u0432\u0438\u043B\u0438
        \u0438\u0438 \u0432\u0440\u043E\u0434\u0435\xBB."
